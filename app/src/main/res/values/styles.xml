<resources>
    <style name="AppTheme" parent="android:style/Theme.Material.NoActionBar">
        <item name="android:windowBackground">@drawable/bg_app_background</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:statusBarColor">@color/topflow_background</item>
        <item name="android:navigationBarColor">@color/topflow_background</item>
        <item name="android:colorBackground">@color/topflow_background</item>
        <item name="android:colorPrimary">@color/topflow_primary</item>
        <item name="android:colorPrimaryDark">@color/topflow_background</item>
        <item name="android:colorAccent">@color/topflow_primary</item>
        <item name="android:textColorPrimary">@color/topflow_text_primary</item>
        <item name="android:textColorSecondary">@color/topflow_text_secondary</item>
        <item name="android:buttonStyle">@style/Widget.TopFlow.Button</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="Widget.TopFlow.Button" parent="android:style/Widget.Button">
        <item name="android:background">@drawable/bg_button_primary</item>
        <item name="android:textColor">@color/topflow_text_primary</item>
        <item name="android:textSize">@dimen/topflow_text_button</item>
        <item name="android:minHeight">@dimen/topflow_button_height</item>
        <item name="android:paddingLeft">@dimen/topflow_space_lg</item>
        <item name="android:paddingTop">@dimen/topflow_space_md</item>
        <item name="android:paddingRight">@dimen/topflow_space_lg</item>
        <item name="android:paddingBottom">@dimen/topflow_space_md</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.TopFlow.Title" parent="android:style/TextAppearance.Material">
        <item name="android:textColor">@color/topflow_text_primary</item>
        <item name="android:textSize">@dimen/topflow_text_title</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.TopFlow.Section" parent="android:style/TextAppearance.Material">
        <item name="android:textColor">@color/topflow_text_primary</item>
        <item name="android:textSize">@dimen/topflow_text_section</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.TopFlow.Body" parent="android:style/TextAppearance.Material">
        <item name="android:textColor">@color/topflow_text_primary</item>
        <item name="android:textSize">@dimen/topflow_text_body</item>
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="TextAppearance.TopFlow.Caption" parent="android:style/TextAppearance.Material">
        <item name="android:textColor">@color/topflow_text_secondary</item>
        <item name="android:textSize">@dimen/topflow_text_caption</item>
        <item name="android:fontFamily">sans-serif-light</item>
    </style>

    <style name="TextAppearance.TopFlow.Chip" parent="android:style/TextAppearance.Material">
        <item name="android:textColor">@color/topflow_text_primary</item>
        <item name="android:textSize">@dimen/topflow_text_chip</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="Widget.TopFlow.Panel" parent="android:style/Widget">
        <item name="android:background">@drawable/bg_surface_panel</item>
    </style>

    <style name="Widget.TopFlow.Sheet" parent="android:style/Widget">
        <item name="android:background">@drawable/bg_surface_sheet</item>
    </style>

    <style name="Widget.TopFlow.Chip" parent="android:style/Widget.Button">
        <item name="android:background">@drawable/bg_chip</item>
        <item name="android:textColor">@color/topflow_text_primary</item>
        <item name="android:textSize">@dimen/topflow_text_chip</item>
        <item name="android:minHeight">@dimen/topflow_chip_height</item>
        <item name="android:paddingLeft">@dimen/topflow_space_lg</item>
        <item name="android:paddingTop">@dimen/topflow_space_xs</item>
        <item name="android:paddingRight">@dimen/topflow_space_lg</item>
        <item name="android:paddingBottom">@dimen/topflow_space_xs</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="TextAppearance.TopFlow21.Title" parent="android:style/TextAppearance.Material">
        <item name="android:textColor">@color/topflow21_text</item>
        <item name="android:textSize">@dimen/topflow21_text_title</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextAppearance.TopFlow21.Section" parent="android:style/TextAppearance.Material">
        <item name="android:textColor">@color/topflow21_text</item>
        <item name="android:textSize">@dimen/topflow21_text_section</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextAppearance.TopFlow21.Body" parent="android:style/TextAppearance.Material">
        <item name="android:textColor">@color/topflow21_text</item>
        <item name="android:textSize">@dimen/topflow21_text_body</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="TextAppearance.TopFlow21.Caption" parent="android:style/TextAppearance.Material">
        <item name="android:textColor">@color/topflow21_text_soft</item>
        <item name="android:textSize">@dimen/topflow21_text_caption</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="Widget.TopFlow21.Control" parent="android:style/Widget.Button">
        <item name="android:background">@drawable/bg21_quiet_control</item>
        <item name="android:textColor">@color/topflow21_text</item>
        <item name="android:textSize">@dimen/topflow21_text_label</item>
        <item name="android:minHeight">48dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:includeFontPadding">false</item>
    </style>

    <style name="Widget.TopFlow21.PrimaryControl" parent="android:style/Widget.Button">
        <item name="android:background">@drawable/bg21_mint_control</item>
        <item name="android:textColor">#06130E</item>
        <item name="android:textSize">@dimen/topflow21_text_label</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:includeFontPadding">false</item>
    </style>
</resources>
