<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/topflow_radius_pill" />
            <solid android:color="#FF49C792" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="@dimen/topflow_radius_pill" />
            <gradient
                android:angle="0"
                android:startColor="#FF4ACD97"
                android:endColor="#FF69E1AF" />
        </shape>
    </item>
</selector>
